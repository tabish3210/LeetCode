PROBLEM   NUMBER                 :                         2515. Shortest Distance to Target String in a Circular Array


// Wednesday, 15 April 2026


// Circular Array Expansion from Start Index 

class Solution {
public:
    int closestTarget(vector<string>& words, string target, int start) {
        int n = words.size();
        for (int i = 0; i <= (n >> 1); i++)
            if (words[(start + i) % n] == target |
                words[(start - i + n) % n] == target)
                return i;
                
        return -1;
    }
};
