// Two-Pointers | Greedy



class Solution {
public:
    int maxDistance(vector<int>& A) {
        int n = A.size();
        int left = 0, right = 0;

        for (int i = 0; i < n; i++)
            if (A[i] ^ A[n - 1]) {
                left = i;
                break;
            }

        for (int i = n - 1; i >= 0; i--)
            if (A[i] ^ A[0]) {
                right = i;
                break;
            }

        return max(n - 1 - left, right);
    }
};

///////////////////////////////////////////////    OR      ////////////////////////////




class Solution {
public:
    int maxDistance(vector<int>& colors) {
        int n = colors.size();
        int ans = 0;

        for(int i = 0; i < n; i++){
            if(colors[i] != colors[0])
                ans = max(ans, i);

            if(colors[i] != colors[n-1])
                ans = max(ans, n-1-i);
        }

        return ans;
    }
};
