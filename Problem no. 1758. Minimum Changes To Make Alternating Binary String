PROBLEM     NUMBER               :               1758. Minimum Changes To Make Alternating Binary String
 

// Thursday, 5 March 2026



// Bit Manipulation

class Solution {
public:
    int minOperations(string s) {
        int count = 0, n = s.length();
        for (int i = 0; i < n; i++)
            count += (s[i] ^ i) & 1;
          
        return min(count, n - count);
    }
};
